# ─── Frontend ──────────────────────────────────────────────────────────────

# Backend API URL (required for auth, courses, progress)
VITE_API_BASE=https://courseforge-production-9253.up.railway.app

# Transcript service URL (optional — same as API_BASE if unified)
VITE_TRANSCRIPT_API_BASE=https://courseforge-production-9253.up.railway.app

# ─── Backend ───────────────────────────────────────────────────────────────

# Railway provides this automatically when you add PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT secret — generate a long random string for production
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# Port (Railway sets this automatically)
PORT=8000
